@page "{id:int}"
@model GymManagement.Web.Pages.Frequencias.DeleteModel
@{ ViewData["Title"] = "Eliminar Frequência"; }
<div class="page-header"><div class="container"><h1><i class="bi bi-trash"></i>Eliminar Registo</h1></div></div>
<div class="row justify-content-center"><div class="col-md-6">
<div class="card border-danger"><div class="card-header bg-danger text-white">Confirmar Eliminação</div>
<div class="card-body">
    <ul class="list-unstyled mb-4">
        <li><strong>Utilizador:</strong> @Model.Frequencia?.Utilizador</li>
        <li><strong>Entrada:</strong> @Model.Frequencia?.Entrada.ToString("dd/MM/yyyy HH:mm")</li>
        <li><strong>Saída:</strong> @(Model.Frequencia?.Saida?.ToString("dd/MM/yyyy HH:mm") ?? "—")</li>
    </ul>
    <form method="post" asp-route-id="@Model.Frequencia?.Id">
        <div class="d-flex gap-2"><button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Eliminar</button><a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a></div>
    </form>
</div></div></div></div>
