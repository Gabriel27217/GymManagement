@* Error.cshtml *@
@page
@model GymManagement.Web.Pages.ErrorModel
@{ ViewData["Title"] = "Erro"; }

<div class="page-header"><div class="container"><h1><i class="bi bi-exclamation-octagon"></i>Erro</h1></div></div>
<div class="row justify-content-center">
    <div class="col-md-6 text-center">
        <div class="card">
            <div class="card-body py-5">
                <i class="bi bi-exclamation-circle" style="font-size:4rem;color:var(--gym-accent)"></i>
                <h3 class="mt-3">Ocorreu um erro</h3>
                <p class="text-muted">@Model.RequestId</p>
                <a asp-page="/Index" class="btn btn-accent mt-3"><i class="bi bi-house me-2"></i>Voltar ao Início</a>
            </div>
        </div>
    </div>
</div>
