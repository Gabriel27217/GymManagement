@page "{id:int}"
@model GymManagement.Web.Pages.PlanosTreino.EditModel
@{ ViewData["Title"] = "Editar Plano de Treino"; }

<div class="page-header"><div class="container"><h1><i class="bi bi-pencil-square"></i>Editar Plano de Treino</h1></div></div>

<div class="row justify-content-center"><div class="col-md-7">
<div class="card"><div class="card-header">Dados do Plano</div><div class="card-body">
<form method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
    <input type="hidden" asp-for="PlanoId" />
    <div class="mb-3">
        <label asp-for="Nome" class="form-label"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Descricao" class="form-label"></label>
        <textarea asp-for="Descricao" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Descricao" class="text-danger small"></span>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="DuracaoMinutos" class="form-label"></label>
            <div class="input-group">
                <input asp-for="DuracaoMinutos" class="form-control" type="number" min="15" max="180" />
                <span class="input-group-text">min</span>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Nivel" class="form-label"></label>
            <select asp-for="Nivel" class="form-select">
                <option value="0">Iniciante</option>
                <option value="1">Intermédio</option>
                <option value="2">Avançado</option>
            </select>
        </div>
    </div>
    <div class="mb-3">
        <label asp-for="Objetivo" class="form-label"></label>
        <select asp-for="Objetivo" class="form-select">
            <option value="0">Geral</option>
            <option value="1">Perda de Peso</option>
            <option value="2">Ganho de Massa</option>
            <option value="3">Resistência</option>
            <option value="4">Reabilitação</option>
            <option value="5">Manutenção</option>
        </select>
    </div>
    <div class="mb-3 form-check">
        <input asp-for="Ativo" class="form-check-input" type="checkbox" />
        <label asp-for="Ativo" class="form-check-label">Ativo</label>
    </div>
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-accent"><i class="bi bi-check-lg me-1"></i>Guardar</button>
        <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>
</div></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
