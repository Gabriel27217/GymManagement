@page
@model GymManagement.Web.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid py-4">
    <h2 class="mb-4">Dashboard — Administração</h2>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Sucesso"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["Erro"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    
    <div class="row g-4 mb-5">
        <div class="col-6 col-md-3">
            <div class="card text-white bg-primary shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="fs-6 fw-semibold">Total de Aulas</div>
                    <div class="display-5 fw-bold mt-2">@Model.TotalAulas</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-white bg-success shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="fs-6 fw-semibold">Planos de Treino</div>
                    <div class="display-5 fw-bold mt-2">@Model.TotalPlanos</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-white bg-info shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="fs-6 fw-semibold">Instrutores</div>
                    <div class="display-5 fw-bold mt-2">@Model.TotalInstrutores</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-white bg-danger shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="fs-6 fw-semibold">Aulas Lotadas</div>
                    <div class="display-5 fw-bold mt-2">@Model.AulasLotadas</div>
                </div>
            </div>
        </div>
    </div>

   
    <h5 class="mb-3">Gestão Rápida</h5>
    <div class="row g-3 mb-5">
        <div class="col-6 col-md-2">
            <a asp-page="/Aulas/Index" class="btn btn-outline-primary w-100">🏋️ Aulas</a>
        </div>
        <div class="col-6 col-md-2">
            <a asp-page="/Instrutores/Index" class="btn btn-outline-success w-100">👤 Instrutores</a>
        </div>
        <div class="col-6 col-md-2">
            <a asp-page="/Salas/Index" class="btn btn-outline-secondary w-100">🚪 Salas</a>
        </div>
        <div class="col-6 col-md-2">
            <a asp-page="/PlanosTreino/Index" class="btn btn-outline-info w-100">📋 Planos</a>
        </div>
        <div class="col-6 col-md-2">
            <a asp-page="/Utilizadores/Index" class="btn btn-outline-warning w-100">👥 Utilizadores</a>
        </div>
        <div class="col-6 col-md-2">
            <a asp-page="/Frequencias/Index" class="btn btn-outline-dark w-100">📊 Frequências</a>
        </div>
    </div>

    
    <h5 class="mb-3">Aulas Ativas</h5>
    @if (!Model.Aulas.Any())
    {
        <div class="alert alert-info">Não há aulas registadas.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Nome</th>
                        <th>Dia</th>
                        <th>Horário</th>
                        <th>Instrutor</th>
                        <th>Sala</th>
                        <th>Vagas</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var aula in Model.Aulas)
                    {
                        <tr>
                            <td>@aula.Nome</td>
                            <td>@aula.DiaSemanaLabel</td>
                            <td>@aula.Hora – @aula.HoraFim</td>
                            <td>@aula.Instrutor</td>
                            <td>@aula.Sala</td>
                            <td>@aula.VagasDisponiveis / @aula.CapacidadeMaxima</td>
                            <td>
                                @if (aula.Lotada)
                                {
                                    <span class="badge bg-danger">Lotada</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Disponível</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>min.</p>