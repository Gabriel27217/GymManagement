@* Edit.cshtml *@
@page "{id:int}"
@model GymManagement.Web.Pages.Instrutores.EditModel
@{ ViewData["Title"] = "Editar Instrutor"; }
<div class="page-header"><div class="container"><h1><i class="bi bi-pencil-square"></i>Editar Instrutor</h1></div></div>
<div class="row justify-content-center"><div class="col-md-6">
<div class="card"><div class="card-header">Editar: @Model.Nome</div><div class="card-body">
<form method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
    <input type="hidden" asp-for="InstrutorId" />
    <div class="mb-3"><label asp-for="Nome" class="form-label"></label><input asp-for="Nome" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Email" class="form-label"></label><input asp-for="Email" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Especialidade" class="form-label"></label><input asp-for="Especialidade" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Telefone" class="form-label"></label><input asp-for="Telefone" class="form-control" /></div>
    <div class="mb-4 form-check">
        <input asp-for="Ativo" class="form-check-input" type="checkbox" />
        <label asp-for="Ativo" class="form-check-label">Ativo</label>
    </div>
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-accent"><i class="bi bi-check-lg me-1"></i>Guardar</button>
        <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>
</div></div></div></div>
