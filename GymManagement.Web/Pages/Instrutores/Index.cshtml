@page
@model GymManagement.Web.Pages.Instrutores.IndexModel
@{ ViewData["Title"] = "Instrutores"; }

<div class="page-header"><div class="container"><h1><i class="bi bi-person-badge"></i>Instrutores</h1></div></div>

<div class="d-flex justify-content-end mb-3">
    <a asp-page="Create" class="btn btn-accent btn-sm"><i class="bi bi-person-plus me-1"></i>Novo Instrutor</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead><tr><th>Nome</th><th>Email</th><th>Especialidade</th><th>Telefone</th><th>Aulas</th><th>Estado</th><th class="text-end">Ações</th></tr></thead>
                <tbody>
                    @foreach (var i in Model.Instrutores)
                    {
                        <tr>
                            <td><strong>@i.Nome</strong></td>
                            <td><a href="mailto:@i.Email" class="text-muted">@i.Email</a></td>
                            <td>@(i.Especialidade ?? "—")</td>
                            <td>@(i.Telefone ?? "—")</td>
                            <td><span class="badge bg-dark">@i.TotalAulas</span></td>
                            <td>
                                @if (i.Ativo)
                                    { <span class="badge bg-success">Ativo</span> }
                                else
                                    { <span class="badge bg-secondary">Inativo</span> }
                            </td>
                            <td class="text-end">
                                <a asp-page="Edit"   asp-route-id="@i.Id" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></a>
                                <a asp-page="Delete" asp-route-id="@i.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Instrutores.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">Nenhum instrutor encontrado.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
