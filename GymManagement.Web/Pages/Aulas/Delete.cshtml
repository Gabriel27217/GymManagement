@* Delete.cshtml *@
@page "{id:int}"
@model GymManagement.Web.Pages.Aulas.DeleteModel
@{ ViewData["Title"] = "Eliminar Aula"; }

<div class="page-header"><div class="container"><h1><i class="bi bi-trash"></i>Eliminar Aula</h1></div></div>
<div class="row justify-content-center"><div class="col-md-6">
<div class="card border-danger">
    <div class="card-header bg-danger text-white"><i class="bi bi-exclamation-triangle me-2"></i>Confirmar Eliminação</div>
    <div class="card-body">
        <ul class="list-unstyled mb-4">
            <li><strong>Nome:</strong> @Model.Aula?.Nome</li>
            <li><strong>Dia:</strong> @Model.Aula?.DiaSemanaLabel</li>
                    <li><strong>Hora:</strong> @Model.Aula?.Hora – @Model.Aula?.HoraFim</li>
            <li><strong>Instrutor:</strong> @Model.Aula?.Instrutor</li>
            <li><strong>Sala:</strong> @Model.Aula?.Sala</li>
            <li class="mt-2 text-danger"><i class="bi bi-exclamation-circle me-1"></i>Todas as inscrições nesta aula serão eliminadas.</li>
        </ul>
        <form method="post" asp-route-id="@Model.Aula?.Id">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Eliminar</button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
</div></div>
