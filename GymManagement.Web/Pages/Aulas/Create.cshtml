@page
@model GymManagement.Web.Pages.Aulas.CreateModel
@{ ViewData["Title"] = "Nova Aula"; }

<div class="page-header"><div class="container"><h1><i class="bi bi-plus-circle"></i>Nova Aula</h1></div></div>
<div class="row justify-content-center"><div class="col-md-7">
<div class="card"><div class="card-header">Dados da Aula</div><div class="card-body">
<form method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="row">
        <div class="col-md-7 mb-3">
            <label asp-for="Nome" class="form-label"></label>
            <input asp-for="Nome" class="form-control" placeholder="Ex: Yoga Relaxante" />
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>
        <div class="col-md-5 mb-3">
            <label asp-for="Categoria" class="form-label"></label>
            <select asp-for="Categoria" class="form-select">
                <option value="1">Yoga</option>
                <option value="2">Pilates</option>
                <option value="3">Spinning</option>
                <option value="4">Musculação</option>
                <option value="5">Zumba</option>
                <option value="6">Boxe</option>
                <option value="7">Natação</option>
                <option value="8">Crossfit</option>
                <option value="99">Outro</option>
            </select>
        </div>
    </div>

    <div class="row">
        <div class="col-md-5 mb-3">
            <label asp-for="DiaSemana" class="form-label"></label>
            <select asp-for="DiaSemana" class="form-select">
                <option value="1">Segunda-feira</option>
                <option value="2">Terça-feira</option>
                <option value="3">Quarta-feira</option>
                <option value="4">Quinta-feira</option>
                <option value="5">Sexta-feira</option>
                <option value="6">Sábado</option>
                <option value="7">Domingo</option>
            </select>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Hora" class="form-label"></label>
            <input asp-for="Hora" class="form-control" type="time" />
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="DuracaoMinutos" class="form-label"></label>
            <div class="input-group">
                <input asp-for="DuracaoMinutos" class="form-control" type="number" min="15" max="180" />
                <span class="input-group-text">min</span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="InstrutorId" class="form-label"></label>
            <select asp-for="InstrutorId" class="form-select">
                <option value="">-- Selecionar Instrutor --</option>
                @foreach (var i in Model.Instrutores)
                {
                    <option value="@i.Id">@i.Nome (@(i.Especialidade ?? "Geral"))</option>
                }
            </select>
            <span asp-validation-for="InstrutorId" class="text-danger small"></span>
        </div>
        <div class="col-md-6 mb-4">
            <label asp-for="SalaId" class="form-label"></label>
            <select asp-for="SalaId" class="form-select">
                <option value="">-- Selecionar Sala --</option>
                @foreach (var s in Model.Salas)
                {
                    <option value="@s.Id">@s.Nome (cap. @s.CapacidadeMaxima)</option>
                }
            </select>
            <span asp-validation-for="SalaId" class="text-danger small"></span>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-accent"><i class="bi bi-check-lg me-1"></i>Guardar</button>
        <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>
</div></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
