@page
@{
    ViewData["Title"] = "Acesso Negado";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <i class="bi bi-shield-lock display-1 text-danger mb-4"></i>
            <h2 class="mb-3">Acesso Negado</h2>
            <p class="text-muted mb-4">
                Não tens permissões para aceder a esta página.<br />
                Se acreditas que isto é um erro, contacta o administrador.
            </p>
            <div class="d-flex justify-content-center gap-3">
                <a asp-page="/Dashboard" class="btn btn-primary">
                    <i class="bi bi-house me-1"></i> Ir para o Dashboard
                </a>
                <a asp-page="/Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Página Inicial
                </a>
            </div>
        </div>
    </div>
</div>
