@page
@model GymManagement.Web.Pages.PlanosTreino.IndexModel
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Planos de Treino";
    var sessaoRole = HttpContext.Session.GetString("Role");
}

<div class="page-header">
    <div class="container">
        <h1><i class="bi bi-journal-text"></i>Planos de Treino</h1>
    </div>
</div>

<div class="d-flex justify-content-end mb-3">
    @if (sessaoRole == "Admin")
    {
        <a asp-page="Create" class="btn btn-accent btn-sm">
            <i class="bi bi-plus-circle me-1"></i>Novo Plano
        </a>
    }
</div>

<div class="row g-3">
    @foreach (var p in Model.Planos)
    {
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>@p.Nome</span>
                    <span class="badge" style="background:var(--gym-accent);color:#000;font-size:.7rem">
                        @p.Nivel
                    </span>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">@p.Descricao</p>
                    <div class="d-flex gap-3">
                        <div><i class="bi bi-clock me-1 text-muted"></i><strong>@p.DuracaoMinutos</strong> min</div>
                        <div><span class="badge" style="background:var(--gym-accent);color:#000">@p.Nivel</span></div>
                    </div>
                </div>
                @if (sessaoRole == "Admin")
                {
                    <div class="card-footer bg-transparent d-flex gap-2">
                        <a asp-page="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil me-1"></i>Editar
                        </a>
                        <a asp-page="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash me-1"></i>Eliminar
                        </a>
                    </div>
                }
            </div>
        </div>
    }

    @if (!Model.Planos.Any())
    {
        <div class="col-12">
            <p class="text-muted text-center py-4">Nenhum plano disponível.</p>
        </div>
    }
</div>