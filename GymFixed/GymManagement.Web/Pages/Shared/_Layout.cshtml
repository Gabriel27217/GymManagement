<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — GymManagement</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --gym-dark:   #0d0d0d;
            --gym-accent: #e8ff00;
            --gym-gray:   #1a1a1a;
            --gym-mid:    #2a2a2a;
        }
        body { font-family: 'Inter', sans-serif; background: #f5f5f5; display: flex; flex-direction: column; min-height: 100vh; }

        /* NAVBAR */
        .navbar { background: var(--gym-dark) !important; border-bottom: 3px solid var(--gym-accent); padding: 0; }
        .navbar-brand { font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 1.6rem; color: var(--gym-accent) !important; letter-spacing: 2px; padding: 12px 20px; }
        .navbar-brand span { color: #fff; }
        .nav-link { font-size: .85rem; font-weight: 500; letter-spacing: .5px; color: #bbb !important; padding: 20px 14px !important; text-transform: uppercase; transition: color .2s; }
        .nav-link:hover, .nav-link.active { color: var(--gym-accent) !important; }
        .nav-link i { margin-right: 5px; }
        .dropdown-menu { background: var(--gym-gray); border: 1px solid var(--gym-mid); border-top: 2px solid var(--gym-accent); }
        .dropdown-item { color: #bbb; font-size: .85rem; }
        .dropdown-item:hover { background: var(--gym-mid); color: var(--gym-accent); }
        .badge-admin { background: var(--gym-accent); color: var(--gym-dark); font-size: .65rem; font-weight: 700; letter-spacing: 1px; padding: 2px 6px; border-radius: 2px; margin-left: 4px; }

        /* MAIN */
        main { flex: 1; padding: 30px 0; }

        /* PAGE HEADER */
        .page-header { background: var(--gym-dark); color: #fff; padding: 24px 0; margin-bottom: 30px; border-bottom: 3px solid var(--gym-accent); }
        .page-header h1 { font-family: 'Oswald', sans-serif; font-size: 1.8rem; letter-spacing: 1px; margin: 0; }
        .page-header h1 i { color: var(--gym-accent); margin-right: 10px; }

        /* CARDS */
        .card { border: none; border-radius: 4px; box-shadow: 0 2px 12px rgba(0,0,0,.08); border-top: 3px solid var(--gym-accent); }
        .card-header { background: var(--gym-dark); color: #fff; font-family: 'Oswald', sans-serif; letter-spacing: 1px; border-radius: 0 !important; padding: 12px 20px; }

        /* TABLES */
        .table th { background: var(--gym-dark); color: var(--gym-accent); font-family: 'Oswald', sans-serif; font-size: .85rem; letter-spacing: 1px; text-transform: uppercase; border: none; font-weight: 400; }
        .table td { vertical-align: middle; border-color: #eee; }
        .table tbody tr:hover { background: #f9f9f0; }

        /* BUTTONS */
        .btn-primary { background: var(--gym-dark); border-color: var(--gym-dark); color: var(--gym-accent); font-weight: 600; }
        .btn-primary:hover { background: #111; border-color: var(--gym-accent); color: var(--gym-accent); }
        .btn-accent { background: var(--gym-accent); border-color: var(--gym-accent); color: var(--gym-dark); font-weight: 700; }
        .btn-accent:hover { background: #d4e800; border-color: #d4e800; color: var(--gym-dark); }

        /* FORMS */
        .form-label { font-weight: 500; font-size: .85rem; color: #555; text-transform: uppercase; letter-spacing: .5px; }
        .form-control:focus, .form-select:focus { border-color: var(--gym-accent); box-shadow: 0 0 0 .2rem rgba(232,255,0,.2); }

        /* STAT CARDS */
        .stat-card { background: var(--gym-dark); color: #fff; border-radius: 4px; padding: 24px; border-left: 4px solid var(--gym-accent); transition: transform .2s; }
        .stat-card:hover { transform: translateY(-3px); }
        .stat-card .number { font-family: 'Oswald', sans-serif; font-size: 2.5rem; color: var(--gym-accent); line-height: 1; }
        .stat-card .label { font-size: .8rem; color: #999; text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }

        /* TOAST SIGNALR */
        #toast-container { position: fixed; bottom: 20px; right: 20px; z-index: 9999; }
        .gym-toast { background: var(--gym-dark); color: #fff; border-left: 4px solid var(--gym-accent); padding: 14px 18px; border-radius: 4px; margin-top: 8px; font-size: .9rem; box-shadow: 0 4px 20px rgba(0,0,0,.3); animation: slideIn .3s ease; }
        .gym-toast.danger { border-left-color: #ff4444; }
        .gym-toast.success { border-left-color: #44ff88; }
        @@keyframes slideIn { from { transform: translateX(100px); opacity: 0; } to { transform: none; opacity: 1; } }

        /* FOOTER */
        footer { background: var(--gym-dark); color: #666; padding: 16px 0; font-size: .8rem; border-top: 2px solid var(--gym-accent); }
        footer a { color: var(--gym-accent); text-decoration: none; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg">
    <div class="container">
        <a class="navbar-brand" asp-page="/Index"><span>GYM</span>MANAGEMENT</a>
        <button class="navbar-toggler border-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
            <span class="navbar-toggler-icon" style="filter:invert(1)"></span>
        </button>
@{
    // FIX: usar User (cookie claims) em vez de Session para verificar autenticação
    // A sessão pode não estar disponível imediatamente após redirect
    var isAuth    = User.Identity?.IsAuthenticated == true;
    var cookieRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    var cookieNome = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
                  ?? ViewContext.HttpContext.Session.GetString("NomeUtilizador")
                  ?? "";
}
        <div class="collapse navbar-collapse" id="nav">
            <ul class="navbar-nav ms-auto align-items-lg-center">

                <li class="nav-item"><a class="nav-link" asp-page="/Index"><i class="bi bi-house"></i>Página Inicial</a></li>
                <li class="nav-item"><a class="nav-link" asp-page="/Sobre"><i class="bi bi-info-circle"></i>Sobre Nós</a></li>
                <li class="nav-item"><a class="nav-link" asp-page="/Aulas/Index"><i class="bi bi-calendar3"></i>Aulas</a></li>
                <li class="nav-item"><a class="nav-link" asp-page="/PlanosTreino/Index"><i class="bi bi-journal-text"></i>Planos de Treino</a></li>

                @if (isAuth && cookieRole != "Admin")
                {
                    <li class="nav-item"><a class="nav-link" asp-page="/MinhasInscricoes"><i class="bi bi-clipboard-check"></i>As Minhas Aulas</a></li>
                }

                @if (cookieRole == "Admin")
                {
                    <li class="nav-item"><a class="nav-link" asp-page="/Dashboard"><i class="bi bi-speedometer2"></i>Dashboard</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-shield-check"></i>Gestão<span class="badge-admin">ADMIN</span>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-page="/Utilizadores/Index"><i class="bi bi-people me-2"></i>Utilizadores</a></li>
                            <li><a class="dropdown-item" asp-page="/Instrutores/Index"><i class="bi bi-person-badge me-2"></i>Instrutores</a></li>
                            <li><a class="dropdown-item" asp-page="/Salas/Index"><i class="bi bi-door-open me-2"></i>Salas</a></li>
                            <li><hr class="dropdown-divider" style="border-color:#333"></li>
                            <li><a class="dropdown-item" asp-page="/Frequencias/Index"><i class="bi bi-person-check me-2"></i>Frequências</a></li>
                        </ul>
                    </li>
                }

                @if (isAuth)
                {
                    <li class="nav-item ms-lg-2">
                        <form method="post" asp-page="/Account/Logout" style="display:inline">
                            <button type="submit" class="btn btn-sm btn-outline-secondary text-white border-secondary">
                                <i class="bi bi-box-arrow-right me-1"></i>Sair (@cookieNome)
                            </button>
                        </form>
                    </li>
                }
                else
                {
                    <li class="nav-item ms-lg-1">
                        <a class="btn btn-sm btn-outline-light me-1" asp-page="/Account/Login">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Entrar
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-sm btn-accent" asp-page="/Account/Register">
                            <i class="bi bi-person-plus me-1"></i>Registar
                        </a>
                    </li>
                }

            </ul>
        </div>
    </div>
</nav>

<main>
    <div class="container">
        @if (TempData["Sucesso"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mt-3">
                <i class="bi bi-check-circle me-2"></i>@TempData["Sucesso"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Erro"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mt-3">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Erro"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>
</main>

<div id="toast-container"></div>

<footer>
    <div class="container d-flex justify-content-between align-items-center">
        <span>&copy; @DateTime.Now.Year GymManagement — Licenciatura em Eng. Informática — Autores: 27217, 24634</span>
        <a asp-page="/Sobre">Sobre o Projeto</a>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.0/dist/browser/signalr.min.js"></script>
<script>
    const apiBase = "https://localhost:7000";
    const connection = new signalR.HubConnectionBuilder()
        .withUrl(apiBase + "/gymhub")
        .withAutomaticReconnect()
        .build();

    function showToast(msg, type = "") {
        const div = document.createElement("div");
        div.className = "gym-toast " + type;
        div.innerHTML = `<i class="bi bi-bell me-2"></i>${msg}`;
        document.getElementById("toast-container").appendChild(div);
        setTimeout(() => div.remove(), 5000);
    }

    connection.on("AulaLotada",     (nome)        => showToast(`⚡ A aula <strong>${nome}</strong> ficou lotada!`, "danger"));
    connection.on("VagasLiberadas", (nome, vagas)  => showToast(`✅ Ficaram ${vagas} vaga(s) disponível(eis) em <strong>${nome}</strong>!`, "success"));
    connection.on("NovoPlano",      (nome)         => showToast(`🆕 Novo plano de treino disponível: <strong>${nome}</strong>`));
    connection.on("AtualizarFrequencias", ()        => { if (window.location.pathname.includes("Frequencias")) location.reload(); });

    connection.start().catch(err => console.warn("SignalR:", err));
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
